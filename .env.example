# Database
DATABASE_URL="postgresql://postgres:password@localhost:5433/employee_tracker"

# App
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Basic auth for admin UI (MVP: simple header check)
# Set a strong random value in production
ADMIN_SECRET="dev-secret-change-me"

# Scan ingestion shared secret (used by Pi clients and manual API callers)
# Individual device API keys are stored (hashed) in the database.
# This env var is used only as a fallback for MANUAL_UI type devices.
INTERNAL_API_SECRET="internal-dev-secret"

# NEXT_PUBLIC_ vars are sent to the browser bundle.
# For MVP the admin secret is passed in browser requests — replace with
# a proper session cookie before exposing to the internet.
NEXT_PUBLIC_ADMIN_SECRET="dev-secret-change-me"
