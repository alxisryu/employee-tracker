# Database
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""

# NextAuth — generate AUTH_SECRET with: openssl rand -hex 32
AUTH_SECRET="generate-with-openssl-rand-hex-32"
AUTH_URL="http://localhost:3000"

# Google OAuth — create at https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Comma-separated emails that receive ADMIN role on first sign-in.
# Add yourself here before anyone else signs in.
ADMIN_EMAILS="you@lyratechnologies.com.au"

# Non-company emails allowed in development only (NODE_ENV != production).
# Never set this in production — it has no effect there.
TEST_EMAILS="personal@gmail.com,colleague@otherdomain.com"

# Shared secret for MANUAL_UI device (web simulator) and future internal use
INTERNAL_API_SECRET="internal-dev-secret"

# Secret for the /api/cron/* endpoints — generate with: openssl rand -hex 16
# Pass as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="generate-with-openssl-rand-hex-16"
