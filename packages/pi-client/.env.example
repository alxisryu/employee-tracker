# URL of the web backend
BACKEND_URL=http://localhost:3000

# Device name as registered in the devices table (e.g. "mock_cli_1")
DEVICE_ID=mock_cli_1

# Plain API key for this device (printed once during pnpm db:seed)
DEVICE_API_KEY=mock-cli-dev-key-1234

# Set to "true" to use MockTagReader (manual CLI entry) instead of real NFC hardware
MOCK_MODE=true

# Duplicate suppression window in milliseconds (default: 30000 = 30s)
# Scans from the same tag within this window are not re-submitted to the backend.
# The backend has its own authoritative suppression — this is a convenience layer.
CLIENT_DEBOUNCE_MS=30000
