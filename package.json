{
  "name": "employee-tracker",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate --filter=@employee-tracker/db",
    "db:push": "turbo db:push --filter=@employee-tracker/db",
    "db:migrate": "turbo db:migrate --filter=@employee-tracker/db",
    "db:seed": "turbo db:seed --filter=@employee-tracker/db",
    "db:studio": "turbo db:studio --filter=@employee-tracker/db"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.5.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ],
    "overrides": {
      "@auth/core": "0.41.1"
    }
  }
}
